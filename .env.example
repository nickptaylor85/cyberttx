# ============================================
# DATABASE (Neon)
# ============================================
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cyberttx?sslmode=require"

# ============================================
# CLERK AUTH
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# ============================================
# ANTHROPIC (TTX Generation)
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# PUSHER (Real-time)
# ============================================
NEXT_PUBLIC_PUSHER_KEY=xxx
NEXT_PUBLIC_PUSHER_CLUSTER=eu
PUSHER_APP_ID=xxx
PUSHER_SECRET=xxx

# ============================================
# STRIPE (Billing)
# ============================================
